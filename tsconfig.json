{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@savig/engine/color": ["packages/engine/src/color.ts"],
      "@savig/engine/gradientAnim": ["packages/engine/src/gradientAnim.ts"],
      "@savig/engine": ["packages/engine/src/index.ts"],
      "@savig/core/node": ["packages/core/src/node.ts"],
      "@savig/core": ["packages/core/src/index.ts"],
      "@savig/interaction": ["packages/interaction/src/index.ts"],
      "@savig/editor-state": ["packages/editor-state/src/index.ts"],
      "@savig/ui-core/*": ["packages/ui-core/src/*.ts"],
      "@savig/ui-core": ["packages/ui-core/src/index.ts"],
      "@savig/services/export/renderDocument": ["packages/services/src/export/renderDocument.ts"],
      "@savig/services": ["packages/services/src/index.ts"],
      "@savig/runtime/runtimeSource.generated": ["packages/runtime/src/runtimeSource.generated.ts"],
      "@savig/runtime/frame": ["packages/runtime/src/frame.ts"],
      "@savig/runtime": ["packages/runtime/src/index.ts"],
      "@savig/mcp": ["packages/mcp/src/server.ts"]
    }
  },
  "include": ["packages", "apps", "vitest.config.ts"]
}
