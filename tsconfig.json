{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "baseUrl": ".",
    "paths": {
      "@savig/engine/color": ["packages/engine/src/color.ts"],
      "@savig/engine/gradientAnim": ["packages/engine/src/gradientAnim.ts"],
      "@savig/engine": ["packages/engine/src/index.ts"],
      "@savig/core/node": ["src/core/render.ts"],
      "@savig/core": ["src/core/index.ts"],
      "@savig/services/export/renderDocument": ["src/services/export/renderDocument.ts"],
      "@savig/services": ["src/services/index.ts"],
      "@savig/runtime/runtimeSource.generated": ["packages/runtime/src/runtimeSource.generated.ts"],
      "@savig/runtime/frame": ["packages/runtime/src/frame.ts"],
      "@savig/runtime": ["packages/runtime/src/index.ts"],
      "@savig/mcp": ["src/mcp/server.ts"]
    }
  },
  "include": ["src", "packages", "apps", "vite.config.ts", "vitest.config.ts"]
}
